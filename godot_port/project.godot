[application]

config/name="MFRG"
run/main_scene="res://scenes/main_intro_game/main_intro_game.tscn"
boot_splash/show_image=false
config/icon="res://assets/blender2.79_old/assets/talk_scenes/characters/anne/indigena/new_icon.png"
config/windows_native_icon="res://assets/blender2.79_old/assets/talk_scenes/characters/anne/indigena/new_icon.ico"

[autoload]

MusicController="*res://scenes/musics/music_controller.tscn"

[display]

window/size/width=1920
window/size/height=1080
window/size/fullscreen=true
window/size/test_width=640
window/size/test_height=360
window/handheld/orientation="portrait"
mouse_cursor/custom_image="res://assets/blender2.79_old/textures/icon_project/mouse_icon.png"
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[global]

zoom=false

[gui]

common/drop_mouse_on_gui_input_disabled=true

[input]

ui_accept={
"deadzone": 0.5,
